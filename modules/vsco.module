#!name=VSCO Premium
#!desc=VSCO Premium

[Script]
vsco = type=http-request,script-path=https://raw.githubusercontent.com/sbunkov/shadowrocket-configuration/main/scripts/vsco.js,pattern=^https?:\/\/api\.revenuecat\.com\/v\d\/subscribers\/,max-size=131072,requires-body=true,timeout=10,script-update-interval=0,enable=true

[MITM]
hostname = %APPEND% api.revenuecat.com
