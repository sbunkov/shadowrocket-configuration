#!name=VlogStar Pro
#!desc=VlogStar Pro
[Script]
vlogstar = type=http-response,script-path=https://raw.githubusercontent.com/sbunkov/shadowrocket-configuration/main/scripts/vlogstar.js,pattern=^https:\/\/buy\.itunes\.apple\.com\/verifyReceipt,requires-body=true,timeout=10,script-update-interval=0,enable=true,max-size=131072

[MITM]
hostname = %APPEND% buy.itunes.apple.com
