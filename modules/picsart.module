#!name=PicsArt Premium
#!desc=PicsArt Premium

[Script]
picsart = type=http-request,pattern=^https:\/\/api\.picsart\.com\/gw-v2\/shop\/subscription\/apple\/purchases,script-path=https://raw.githubusercontent.com/sbunkov/shadowrocket-configuration/main/scripts/picksart.js,requires-body=true,max-size=131072,timeout=10,script-update-interval=0,enable=true

[MITM]
hostname = %APPEND% api.picsart.com
